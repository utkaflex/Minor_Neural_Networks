   "source": [
    "Размер изображения в датасете 1, 28, 28.\n",
    "1 канал (ч/б), высота 28 и ширина 28.\n",
    "\n",
    "Для обратной свёртки размер считается по формуле:\n",
    "$$H_{out} = (H_{in} − 1) · stride − 2·padding + kernelsize$$"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 131,
   "id": "5144e17a-a292-4aa6-b612-230bb62aeb7c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# генератор, он рисует картинки одежды\n",
    "noise_dimension = 100  # размер вектора шума\n",
    "\n",
    "class Generator(nn.Module):\n",
    "    def __init__(self, noise_dimension=100):\n",
    "        super().__init__()\n",
    "        self.net = nn.Sequential(\n",
    "            # вход: (batch, noise_dimension, 1, 1)\n",
    "            nn.ConvTranspose2d(noise_dimension, 128, kernel_size=7, stride=1, padding=0),\n",
    "            nn.BatchNorm2d(128),\n",
    "            nn.ReLU(True), # (batch, 128, 7, 7)\n",
    "\n",
    "            nn.ConvTranspose2d(128, 64, kernel_size=4, stride=2, padding=1),\n",
    "            nn.BatchNorm2d(64),\n",
    "            nn.ReLU(True), # (batch, 64, 14, 14)\n",
    "\n",
    "            nn.ConvTranspose2d(64, 1, kernel_size=4, stride=2, padding=1),\n",
    "            nn.Tanh() # (batch, 1, 28, 28)\n",
    "        )\n",
    "\n",
    "    def forward(self, z):\n",
    "        # превращаем вектор шума (batch, noise_dimension) в тензор вида (batch, noise_dimension, 1, 1)\n",
    "        z = z.view(z.size(0), z.size(1), 1, 1)\n",
    "        img = self.net(z)\n",
    "        return img"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "70957c5f-a1dd-4db5-9c9f-f949b780b39a",
   "metadata": {},
   "source": [
    "LeakyReLU — это функция активации, которая для положительных значений работает как обычный ReLU, а для отрицательных оставляет небольшое значение вместо нуля. \n",
    "\n",
    "В отличие от ReLU, который обнуляет все отрицательные значения, LeakyReLU пропускает через себя часть отрицательных значений, поэтому градиент там не становится нулём и сеть обучается стабильнее."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 132,
   "id": "76a15976-e5bf-4d87-baf3-d5d699024525",
   "metadata": {},
   "outputs": [],
   "source": [
    "# дискриминатор, приниимает на вход картинку и решает настоящая она или нет\n",
    "class Discriminator(nn.Module):\n",
    "    def __init__(self):\n",
    "        super().__init__()\n",
    "        self.net = nn.Sequential(\n",
    "            # вход: (batch, 1, 28, 28)\n",
    "            nn.Conv2d(1, 64, kernel_size=4, stride=2, padding=1, bias=False),\n",
    "            nn.LeakyReLU(0.2), # (batch, 64, 14, 14)\n",
    "\n",
    "            nn.Conv2d(64, 128, kernel_size=4, stride=2, padding=1, bias=False),\n",
    "            nn.BatchNorm2d(128),\n",
    "            nn.LeakyReLU(0.2), # (batch, 128, 7, 7)\n",
    "\n",
    "            nn.Flatten(), # (batch, 128*7*7)\n",
    "            nn.Linear(128 * 7 * 7, 1),\n",
    "            nn.Sigmoid() # вероятность настоящей картинки\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        return self.net(x)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 133,
   "id": "0bb00ed4-71a5-45b1-8778-d26dcd999481",
   "metadata": {},
   "outputs": [],
   "source": [
    "generator = Generator(noise_dimension).to(device)\n",
    "discriminator = Discriminator().to(device)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 134,
   "id": "f1265886-b51e-47e6-b1f4-8a36673bbd47",
   "metadata": {},
   "outputs": [],
   "source": [
    "criterion = nn.BCELoss()\n",
    "lr = 0.0002"
   ]
  },
  {
