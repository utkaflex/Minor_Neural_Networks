   "metadata": {},
   "outputs": [],
   "source": [
    "# train и test датасета FashionMNIST\n",
    "train_dataset = torchvision.datasets.FashionMNIST(\n",
    "    root=\"./data_fashion\",\n",
    "    train=True,\n",
    "    transform=transform,\n",
    "    download=True\n",
    ")\n",
    "\n",
    "test_dataset = torchvision.datasets.FashionMNIST(\n",
    "    root=\"./data_fashion\",\n",
    "    train=False,\n",
    "    transform=transform,\n",
    "    download=True\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
