    "    # Убираем HTML-теги, которые обозначают новый абзац и т.д.\n",
    "    text = re.sub(r'<[^>]+>', ' ', text)\n",
    "    # Убираем URL, потому что где-то там я их видела\n",
    "    text = re.sub(r'http\\S+', '', text)\n",
    "    # Убираем лишние пробелы, переносы и т.д.\n",
    "    text = re.sub(r'\\s+', ' ', text).strip()\n",
    "    return text"
