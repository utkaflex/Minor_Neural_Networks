    "import time\n",
    "\n",
    "# --- 3.3 Обучение ---\n",
    "optimizer = AdamW(model.parameters(), lr=LR)\n",
    "total_steps = len(train_loader) * EPOCHS\n",
    "scheduler = get_linear_schedule_with_warmup(\n",
    "    optimizer, num_warmup_steps=total_steps//10, num_training_steps=total_steps\n",
    ")\n",
    "criterion = nn.BCEWithLogitsLoss()\n",
    "\n",
    "# ← ДОБАВЛЕНО: функция evaluate\n",
    "def evaluate(loader):\n",
    "    model.eval()\n",
    "    total_loss = 0\n",
    "    all_logits, all_labels = [], []\n",
    "    with torch.no_grad():\n",
    "        for batch in loader:\n",
    "            ids  = batch['input_ids'].to(DEVICE)\n",
    "            mask = batch['attention_mask'].to(DEVICE)\n",
    "            lbls = batch['labels'].to(DEVICE)\n",
    "            logits = model(ids, mask)\n",
    "            total_loss += criterion(logits, lbls).item()\n",
    "            all_logits.append(torch.sigmoid(logits).cpu())\n",
    "            all_labels.append(lbls.cpu())\n",
    "    return total_loss / len(loader), torch.cat(all_logits), torch.cat(all_labels)\n",
    "\n",
    "def format_time(seconds):\n",
    "    h = int(seconds // 3600)\n",
    "    m = int((seconds % 3600) // 60)\n",
    "    s = int(seconds % 60)\n",
    "    if h > 0:\n",
    "        return f\"{h}ч {m}м {s}с\"\n",
    "    elif m > 0:\n",
    "        return f\"{m}м {s}с\"\n",
    "    else:\n",
    "        return f\"{s}с\"\n",
    "\n",
    "history = {'train_loss': [], 'val_loss': []}\n",
    "total_start = time.time()\n",
    "\n",
    "for epoch in range(EPOCHS):\n",
    "    epoch_start = time.time()\n",
    "    model.train()\n",
    "    train_loss = 0\n",
    "\n",
    "    for step, batch in enumerate(train_loader):\n",
    "        ids  = batch['input_ids'].to(DEVICE)\n",
    "        mask = batch['attention_mask'].to(DEVICE)\n",
    "        lbls = batch['labels'].to(DEVICE)\n",
    "\n",
    "        optimizer.zero_grad()\n",
    "        logits = model(ids, mask)\n",
    "        loss = criterion(logits, lbls)\n",
    "        loss.backward()\n",
    "        nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n",
    "        optimizer.step()\n",
    "        scheduler.step()\n",
    "        train_loss += loss.item()\n",
    "\n",
    "        if (step + 1) % 20 == 0 or (step + 1) == len(train_loader):\n",
    "            elapsed     = time.time() - epoch_start\n",
    "            steps_done  = step + 1\n",
    "            steps_total = len(train_loader)\n",
    "            eta_epoch   = elapsed / steps_done * (steps_total - steps_done)\n",
    "            avg_epoch_time = (time.time() - total_start) / (epoch + steps_done / steps_total)\n",
    "            eta_total   = avg_epoch_time * (EPOCHS - epoch - steps_done / steps_total)\n",
    "\n",
    "            print(\n",
    "                f\"  Эпоха {epoch+1}/{EPOCHS} | \"\n",
    "                f\"Шаг {steps_done}/{steps_total} | \"\n",
    "                f\"Loss: {train_loss/steps_done:.4f} | \"\n",
    "                f\"Эпоха через: {format_time(eta_epoch)} | \"\n",
    "                f\"Всего осталось: {format_time(eta_total)}\",\n",
    "                end='\\r'\n",
    "            )\n",
    "\n",
    "    val_loss, _, _ = evaluate(val_loader)\n",
    "    epoch_time = time.time() - epoch_start\n",
